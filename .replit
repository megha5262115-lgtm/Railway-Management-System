modules = ["java-graalvm22.3"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Railway Booking System"

[[workflows.workflow]]
name = "Railway Booking System"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "java -cp \"build:lib/*\" com.railway.RailwayApp"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
